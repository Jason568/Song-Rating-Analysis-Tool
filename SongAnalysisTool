        showSplash();
        firstMenu();
        
        try {
            reader.close();  
        } catch (IOException e) {
            System.err.println("Warning: Failed to close reader");
        }
        return;
    }
    
    if (args.length < 2) {
        System.err.println(
            "Error: Incorrect number of arguments. Usage: java Cs214Project <input-file> <output-file> [-u|-p|-r song1,song2,...]");
        System.err.println("Or for interactive mode: java Cs214Project -i");
        return;
    }

    String inputFile = args[0];
    String outputFile = args[1];
    boolean userSimilarityMode = args.length == 3 && args[2].equals("-u");
    boolean predictionMode = args.length == 3 && args[2].equals("-p");
    boolean recommendationMode = args.length > 2 && args[2].startsWith("-r");

    if (args.length == 3 && !userSimilarityMode && !predictionMode && !recommendationMode) {
        System.err.println("Error: unsupported argument '" + args[2] + "'");
        return;
    }

    // Validate input file
    File input = new File(inputFile);
    if (!input.exists()) {
        System.err.println("Error: input file " + inputFile + " does not exist");
        return;
    }
    if (input.length() == 0) {
        System.err.println("Error: input file " + inputFile + " is empty");
        return;
    }
    if (!inputFile.endsWith(".csv")) {
        System.err.println("Error: input file " + inputFile + " is not a CSV file");
        return;
    }

    try {
        File output = new File(outputFile);
        File outputDir = output.getParentFile();
        if (outputDir != null && !outputDir.exists()) {
            System.err.println("Error: output directory " + outputDir + " does not exist");
            return;
        }

        if (userSimilarityMode) {
            computeUserSimilarities(inputFile, outputFile);
        } else if (predictionMode) {
            computePredictions(inputFile, outputFile);
        } else if (recommendationMode) {
            if (args.length < 4) {
                System.err.println("Error: must select at least one song for recommendations");
                return;
            }
            List<String> centroids = Arrays.asList(Arrays.copyOfRange(args, 3, args.length));
            computeRecommendations(inputFile, outputFile, centroids);
        } else {
            Map<String, SongStats> songStatsMap = processCSV(inputFile);
            writeOutputCSV(outputFile, songStatsMap);
        }
    } catch (IOException e) {
        System.err.println("Error: " + e.getMessage());
    }
}

